linters: linters_with_defaults(line_length_linter = line_length_linter(140L), object_name_linter = NULL, object_length_linter = object_length_linter(length = 60L), indentation_linter = NULL, quotes_linter = NULL, commented_code_linter = NULL)
exclusions: list("R/extendr-wrappers.R", "inst/benchmarks", "examples", "vignettes", "data-raw", "tests")
